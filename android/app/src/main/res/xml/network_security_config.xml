<?xml version="1.0" encoding="utf-8"?>
<!-- Allows plain http:// during local development against a LAN backend.
     Remove the cleartext exception once VITE_API_URL points at an https:// server. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
