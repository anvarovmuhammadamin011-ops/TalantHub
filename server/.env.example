# PostgreSQL (Neon — https://neon.tech). Use the POOLED connection string (hostname
# contains "-pooler"), e.g.:
# postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Set to "false" to skip seeding the demo dataset (fake specialists/vacancies/orders/
# chats) on a fresh database — only the admin account is created. Leave unset (defaults
# to on) to have a freshly created database populated with explorable demo content.
SEED_DEMO_DATA=

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
# Faqat login jarayonida vaqtincha kerak:
TELEGRAM_CODE=
TELEGRAM_PASSWORD=

TELEGRAM_CHANNEL=UstozShogird
TELEGRAM_IMPORT_LIMIT=100
TELEGRAM_SCAN_LIMIT=1500

# Password for the auto-created admin account (admin@talenthub.uz), read on
# server startup. Only used the first time the admin account is created.
# If left unset, a random password is generated on first run and printed
# once to the server console — copy it from there.
ADMIN_PASSWORD=

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/callback/google
FRONTEND_URL=http://localhost:5173

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=

# Sentry error monitoring (https://sentry.io) — backend. Leave unset to disable entirely
# (no code path runs, no network calls). Also set VITE_SENTRY_DSN in the root .env for
# frontend error reporting — usually the same project, same DSN.
SENTRY_DSN=
