# Used by the Android/Capacitor build (and optionally the web build) so the
# app knows where to reach the backend. Leave unset for local web dev — the
# Vite dev server proxies /api to http://localhost:4000 already.
#
# For an Android device/emulator, "localhost" means the phone itself, so this
# must be your computer's LAN IP (or a deployed backend URL), e.g.:
# VITE_API_URL=http://192.168.1.20:4000/api
VITE_API_URL=
